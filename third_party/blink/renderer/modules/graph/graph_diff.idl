// GraphDiff — describes a set of changes to a graph.

[Exposed=(Window,Worker)]
interface GraphDiff {
  readonly attribute USVString revision;
  readonly attribute any additions;
  readonly attribute any removals;
  readonly attribute any dependencies;
  readonly attribute USVString author;
  readonly attribute unsigned long long timestamp;
};
