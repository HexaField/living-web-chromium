// SignedTriple — a SemanticTriple with cryptographic provenance.

[Exposed=(Window,Worker)]
interface SignedTriple {
  readonly attribute SemanticTriple data;
  readonly attribute USVString author;
  readonly attribute DOMString timestamp;
  readonly attribute ContentProof proof;
};
