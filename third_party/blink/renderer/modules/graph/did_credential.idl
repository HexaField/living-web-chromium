// DIDCredential — represents a decentralised identity credential.

[Exposed=Window, SecureContext]
interface DIDCredential {
  readonly attribute USVString id;
  readonly attribute USVString did;
  readonly attribute USVString algorithm;
  readonly attribute USVString displayName;
  readonly attribute USVString createdAt;
  readonly attribute boolean isLocked;

  [CallWith=ScriptState, NewObject] Promise<any> sign(USVString dataJson);
  [CallWith=ScriptState, NewObject] Promise<boolean> verify(any signedContent);
  [CallWith=ScriptState, NewObject] Promise<any> resolve();
  [CallWith=ScriptState, NewObject] Promise<boolean> lock();
  [CallWith=ScriptState, NewObject] Promise<boolean> unlock();
};
