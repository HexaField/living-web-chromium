// PersonalGraphManager — navigator.graph entry point.

[Exposed=Window, SecureContext]
interface PersonalGraphManager {
  [CallWith=ScriptState, NewObject] Promise<any> create(optional DOMString name);
  [CallWith=ScriptState, NewObject] Promise<any> list();
  [CallWith=ScriptState, NewObject] Promise<any> get(USVString uuid);
  [CallWith=ScriptState, NewObject] Promise<any> remove(USVString uuid);
  [CallWith=ScriptState, NewObject] Promise<any> join(USVString sharedGraphURI);
  [CallWith=ScriptState, NewObject] Promise<any> listShared();

  // DID Identity
  [CallWith=ScriptState, NewObject] Promise<any> createIdentity(optional DOMString displayName = "");
  [CallWith=ScriptState, NewObject] Promise<any> listIdentities();
  [CallWith=ScriptState, NewObject] Promise<any> activeIdentity();
};
