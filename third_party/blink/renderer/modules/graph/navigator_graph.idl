// PersonalGraphManager — navigator.graph entry point.

[Exposed=Window, SecureContext]
partial interface Navigator {
  [SameObject] readonly attribute PersonalGraphManager graph;
};

dictionary TripleQuery {
  USVString? source;
  USVString? target;
  USVString? predicate;
  DOMString? fromDate;
  DOMString? untilDate;
  unsigned long? limit;
};

enum GraphSyncState { "private", "syncing", "synced", "error" };
enum GraphAccessLevel { "read", "readwrite" };

dictionary SparqlResult {
  USVString type;                          // "bindings" or "graph"
  sequence<object> bindings;               // for SELECT
  sequence<SemanticTriple>? triples;       // for CONSTRUCT
};

[Exposed=Window, SecureContext]
interface PersonalGraphManager {
  [NewObject] Promise<PersonalGraph> create(optional DOMString name);
  [NewObject] Promise<sequence<PersonalGraph>> list();
  [NewObject] Promise<PersonalGraph?> get(USVString uuid);
  [NewObject] Promise<boolean> remove(USVString uuid);
  // From P2P Sync spec
  [NewObject] Promise<SharedGraph> join(USVString sharedGraphURI);
  [NewObject] Promise<sequence<SharedGraphInfo>> listShared();
};
