// SemanticTriple — a single assertion: source → predicate → target.

[Exposed=(Window,Worker)]
interface SemanticTriple {
  constructor(USVString source, USVString target,
              optional USVString? predicate = null);
  readonly attribute USVString source;
  readonly attribute USVString target;
  readonly attribute USVString? predicate;
};
