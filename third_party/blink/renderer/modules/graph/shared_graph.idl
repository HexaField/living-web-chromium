// SharedGraph — a PersonalGraph extended with P2P sync capabilities.
// Spec 03: https://github.com/HexaField/w3c-living-web-proposals/blob/main/drafts/03_p2p-graph-sync.md
// Spec 05: https://github.com/HexaField/w3c-living-web-proposals/blob/main/drafts/05_graph-governance.md

enum SyncState { "idle", "syncing", "synced", "error" };

[Exposed=(Window,Worker), SecureContext]
interface SharedGraph : PersonalGraph {
  readonly attribute USVString uri;
  readonly attribute USVString moduleHash;
  readonly attribute SyncState syncState;

  // Peer operations (Spec 03 §5.2)
  [NewObject, CallWith=ScriptState] Promise<any> peers();
  [NewObject, CallWith=ScriptState] Promise<any> onlinePeers();

  // Revision (Spec 03 §6)
  [NewObject, CallWith=ScriptState] Promise<any> currentRevision();

  // Signalling (Spec 03 §9)
  [CallWith=ScriptState] Promise<undefined> sendSignal(USVString remoteDid, any payload);
  [CallWith=ScriptState] Promise<undefined> broadcast(any payload);

  // Governance queries (Spec 05 §9)
  [NewObject, CallWith=ScriptState] Promise<any> canAddTriple(any triple);
  [NewObject, CallWith=ScriptState] Promise<any> constraintsFor(optional USVString? scopeEntity = null);
  [NewObject, CallWith=ScriptState] Promise<any> myCapabilities();

  // Events (Spec 03)
  attribute EventHandler onpeerjoined;
  attribute EventHandler onpeerleft;
  attribute EventHandler onsyncstatechange;
  attribute EventHandler onsignal;
  attribute EventHandler ondiff;
};
