// SharedGraph — a PersonalGraph extended with P2P sync capabilities.

enum SyncState { "idle", "syncing", "synced", "error" };

[Exposed=(Window,Worker), SecureContext]
interface SharedGraph : PersonalGraph {
  readonly attribute USVString uri;
  readonly attribute SyncState syncState;

  [NewObject] Promise<any> peers();
  [NewObject] Promise<any> onlinePeers();

  [NewObject] Promise<any> sendSignal(USVString remoteDid, any payload);
  [NewObject] Promise<any> broadcast(any payload);

  // Governance queries
  [NewObject] Promise<any> canAddTriple(USVString predicate, optional USVString? scopeEntity = null);
  [NewObject] Promise<any> constraintsFor(optional USVString? scopeEntity = null);
  [NewObject] Promise<any> myCapabilities();

  attribute EventHandler onpeerjoined;
  attribute EventHandler onpeerleft;
  attribute EventHandler onsyncstatechange;
  attribute EventHandler onsignal;
};
