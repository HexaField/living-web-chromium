// PersonalGraph — a named, persistent collection of signed triples.
// Spec: https://github.com/HexaField/w3c-living-web-proposals/blob/main/drafts/01_personal-linked-data-graphs.md

enum GraphSyncState { "private", "syncing", "synced", "error" };

[Exposed=(Window,Worker), SecureContext]
interface PersonalGraph : EventTarget {
  readonly attribute USVString uuid;
  readonly attribute DOMString? name;
  readonly attribute GraphSyncState state;

  // Triple operations (Spec 01 §4.2)
  [CallWith=ScriptState, NewObject] Promise<any> addTriple(any triple);
  [CallWith=ScriptState, NewObject] Promise<any> addTriples(any triples);
  [CallWith=ScriptState, NewObject] Promise<any> removeTriple(any triple);
  [CallWith=ScriptState, NewObject] Promise<any> queryTriples(any query);
  [CallWith=ScriptState, NewObject] Promise<any> querySparql(USVString sparql);
  [CallWith=ScriptState, NewObject] Promise<any> snapshot();

  // Cross-origin sharing (Spec 01 §6.3)
  [CallWith=ScriptState, NewObject] Promise<undefined> grantAccess(USVString origin, DOMString level);
  [CallWith=ScriptState, NewObject] Promise<undefined> revokeAccess(USVString origin);

  // Shape operations (Spec 01 §5 + Spec 04 §5)
  [CallWith=ScriptState, NewObject] Promise<undefined> addShape(DOMString name, DOMString shapeJson);
  [CallWith=ScriptState, NewObject] Promise<any> getShapes();
  [CallWith=ScriptState, NewObject] Promise<any> getShapeInstances(DOMString shapeName);
  [CallWith=ScriptState, NewObject] Promise<USVString> createShapeInstance(DOMString shapeName, USVString address, optional any initialValues);
  [CallWith=ScriptState, NewObject] Promise<any> getShapeInstanceData(DOMString shapeName, USVString address);
  [CallWith=ScriptState, NewObject] Promise<undefined> setShapeProperty(DOMString shapeName, USVString address, DOMString property, any value);
  [CallWith=ScriptState, NewObject] Promise<undefined> addToShapeCollection(DOMString shapeName, USVString address, DOMString collection, any value);
  [CallWith=ScriptState, NewObject] Promise<undefined> removeFromShapeCollection(DOMString shapeName, USVString address, DOMString collection, any value);

  // Sharing — converts to SharedGraph (Spec 03 §5.1)
  [CallWith=ScriptState, NewObject] Promise<any> share(optional any options);

  // Events (Spec 01 §4.2)
  attribute EventHandler ontripleadded;
  attribute EventHandler ontripleremoved;
};
