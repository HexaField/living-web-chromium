// PersonalGraph — a named, persistent collection of signed triples.

enum GraphSyncState { "private", "syncing", "synced", "error" };

[Exposed=(Window,Worker), SecureContext]
interface PersonalGraph : EventTarget {
  readonly attribute USVString uuid;
  readonly attribute DOMString? name;
  readonly attribute GraphSyncState state;

  // Triple operations
  [NewObject] Promise<any> addTriple(any triple);
  [NewObject] Promise<any> addTriples(any triples);
  [NewObject] Promise<any> removeTriple(any triple);
  [NewObject] Promise<any> queryTriples(any query);
  [NewObject] Promise<any> querySparql(USVString sparql);
  [NewObject] Promise<any> snapshot();

  // Cross-origin sharing
  [NewObject] Promise<any> grantAccess(USVString origin, DOMString level);
  [NewObject] Promise<any> revokeAccess(USVString origin);

  // Shape operations
  [NewObject] Promise<any> addShape(USVString name, USVString shaclJson);
  [NewObject] Promise<any> getShapeInstances(USVString shapeName);
  [NewObject] Promise<any> createShapeInstance(USVString shapeName, any data);
  [NewObject] Promise<any> getShapeInstanceData(USVString shapeName, USVString instanceUri);

  // Sharing — converts to SharedGraph
  [NewObject] Promise<any> share(optional any options);

  // Events
};
